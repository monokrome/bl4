{
  "identifier": "default",
  "description": "Default capabilities for the save editor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }]
    }
  ]
}
